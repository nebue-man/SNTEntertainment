# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/snt_events?schema=public"

# JWT — generate a long random secret: openssl rand -base64 64
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="10h"

# Cloudinary — from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# CORS — the exact origin of your Next.js frontend (no trailing slash)
FRONTEND_URL="http://localhost:3333"

# Port (optional, defaults to 4000)
PORT=4000

# --- Seed-only variables (only read by prisma/seed.ts, not the running server) ---
SEED_ADMIN_EMAIL="admin@sntevents.lk"
SEED_ADMIN_PASSWORD="changeme-before-production"

# --- Docker Compose variables ---
# These are used by docker-compose.yml to create the postgres service and
# override DATABASE_URL so the backend connects to the container, not localhost.
POSTGRES_USER=snt
POSTGRES_PASSWORD=changeme-docker-2026
POSTGRES_DB=snt_events
