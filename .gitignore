# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Frontend (frontend/) ───────────────────────────────────────────────────────

# dependencies
frontend/node_modules
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# testing
frontend/coverage

# next.js build output
frontend/.next/
frontend/out/
frontend/build

# typescript incremental build info
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# env files
frontend/.env*

# vercel
frontend/.vercel

# dev / verification scripts
frontend/verify_snt.js

# ── Backend (backend/) ────────────────────────────────────────────────────────

backend/node_modules
backend/dist
backend/uploads
backend/.env
backend/*.log

# ── Root / shared ─────────────────────────────────────────────────────────────

.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
